# 【必須】GAS Web App のURL（gas/Code.gs をデプロイして発行されたURL）
# スタッフ・シフト種別・確定シフトはすべてこのGAS経由でスプレッドシートに保存される。
# 未設定の場合、アプリはデータを保存できず起動画面で設定を促すメッセージのみ表示する。
VITE_GAS_ENDPOINT_URL=https://script.google.com/macros/s/xxxxxxxxxxxx/exec

# 【必須】gas/Code.gs のスクリプトプロパティ ACCESS_TOKEN と同じ値を設定
VITE_GAS_ACCESS_TOKEN=

# 【任意】Googleログインを有効にする場合に設定（Google Cloud Console で発行するOAuthクライアントID）
# 未設定の場合はログインなしで誰でも利用できる
VITE_GOOGLE_CLIENT_ID=

# 【任意】ログインを許可するメールアドレス（カンマ区切り）。未設定なら全員許可。
# 注意: これはクライアント側のみの簡易チェックであり、真のアクセス制御ではない。
VITE_ALLOWED_STAFF_EMAILS=staff1@example.com,staff2@example.com

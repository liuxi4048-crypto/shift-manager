# Googleログインを有効にする場合に設定（Google Cloud Console で発行するOAuthクライアントID）
# 未設定の場合はログインなしで誰でも利用できる（開発・検証向け）
VITE_GOOGLE_CLIENT_ID=

# ログインを許可するメールアドレス（カンマ区切り）。未設定なら全員許可。
# 注意: これはクライアント側のみの簡易チェックであり、真のアクセス制御ではない。
VITE_ALLOWED_STAFF_EMAILS=staff1@example.com,staff2@example.com

# GAS Web App のURL（gas/Code.gs をデプロイして発行されたURL）
VITE_GAS_ENDPOINT_URL=https://script.google.com/macros/s/xxxxxxxxxxxx/exec

# gas/Code.gs のスクリプトプロパティ ACCESS_TOKEN と同じ値を設定
VITE_GAS_ACCESS_TOKEN=
